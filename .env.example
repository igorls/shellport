# Shellport does not use environment variables for configuration.
# All settings are passed via CLI flags:
#
#   --dev         Development mode (relaxed origin checks)
#   --no-totp     Disable TOTP authentication
#   --no-secret   Disable URL secret authentication
#   --totp-reset  Reset TOTP pairing
#
# TOTP secret is stored in ~/.shellport-totp-secret (not in env)
