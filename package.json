{
  "name": "shellport",
  "version": "0.2.0",
  "description": "Zero-dependency encrypted terminal bridge with TOTP 2FA and built-in web UI. Share your shell over the network with E2E encryption, powered by Bun.",
  "type": "module",
  "bin": {
    "shellport": "./src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./nanoterm": "./src/frontend/nanoterm/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts server --dev",
    "build": "bun build ./src/index.ts --compile --minify --bytecode --outfile shellport",
    "build:frontend": "bun run src/frontend/bundle.ts",
    "build:binaries": "bun run scripts/build-binaries.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "knip": "knip",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "keywords": [
    "terminal",
    "pty",
    "websocket",
    "encryption",
    "totp",
    "2fa",
    "authenticator",
    "shell",
    "remote",
    "bun",
    "zero-dependency",
    "canvas",
    "vt100",
    "xterm"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "src/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "knip": "^6.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1",
    "vitepress": "^1.6.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.js": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
